{
  "name": "@codesign-eu/utils",
  "version": "1.0.24",
  "description": "Utility helpers for spatial, date/time, and Maidenhead grid operations used by Codesign applications.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "npm run build",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest -- --watch",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "version:auto": "node scripts/bump-version-on-main.mjs",
    "version:major": "npm version major --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:patch": "npm version patch --no-git-tag-version"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run format",
      "npm run lint",
      "npm run test"
    ]
  },
  "keywords": [
    "utilities",
    "geospatial",
    "geojson",
    "maidenhead",
    "datetime"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/msciborowski/codesign-utils.git"
  },
  "homepage": "https://github.com/msciborowski/codesign-utils#readme",
  "bugs": {
    "url": "https://github.com/msciborowski/codesign-utils/issues"
  },
  "author": "Marcin Sciborowski",
  "license": "ISC",
  "dependencies": {
    "@turf/turf": "^7.3.1",
    "date-fns": "^3.6.0",
    "geojson": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.0.11",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.5"
  }
}
